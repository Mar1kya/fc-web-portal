// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(USER)
  accounts      Account[]
  sessions      Session[]
  orders        Order[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

model Media {
  id           String             @id @default(cuid())
  url          String
  type         MediaType          @default(IMAGE)
  translations MediaTranslation[]
  posts        Post[]
  players      Player[]
  coaches      Coach[]
  products     Product[]
  galleries    Gallery[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([deletedAt])
}

model MediaTranslation {
  id       String @id @default(cuid())
  mediaId  String
  media    Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  language String @db.VarChar(5)
  altText  String

  @@unique([mediaId, language])
}

enum PostType {
  NEWS
  INTERVIEW
  STATEMENT
}

enum TeamContext {
  MAIN_TEAM
  U19
  ACADEMY
  GENERAL
}

model Post {
  id               String            @id @default(cuid())
  slug             String            @unique
  translations     PostTranslation[]
  media            Media[]
  type             PostType          @default(NEWS)
  teamContext      TeamContext       @default(GENERAL)
  isPublished      Boolean           @default(true)
  publishedAt      DateTime          @default(now())
  mentionedPlayers Player[]
  mentionedCoaches Coach[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
  @@index([publishedAt]) 
  @@index([isPublished]) 
  @@index([type]) 
  @@index([teamContext])
}

model PostTranslation {
  id          String  @id @default(cuid())
  postId      String
  post        Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  language    String  @db.VarChar(5)
  title       String
  description String?
  content     String  @db.Text

  @@unique([postId, language])
  @@index([language])
}

model Gallery {
  id           String               @id @default(cuid())
  slug         String               @unique
  translations GalleryTranslation[]
  coverUrl     String
  media        Media[]
  matchId      String?
  match        Match?               @relation(fields: [matchId], references: [id])

  publishedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([deletedAt])
}

model GalleryTranslation {
  id        String  @id @default(cuid())
  galleryId String
  gallery   Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  language String @db.VarChar(5)
  title    String

  @@unique([galleryId, language])
}

enum PlayerPosition {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
}

model Player {
  id               String              @id @default(cuid())
  slug             String              @unique
  translations     PlayerTranslation[]
  number           Int
  position         PlayerPosition
  teamContext      TeamContext         @default(MAIN_TEAM)
  avatar           String?
  media            Media[]
  birthDate        DateTime?
  height           Int?
  weight           Int?
  nationality      String?             @db.VarChar(10)
  initialMatches   Int                 @default(0)
  initialGoals     Int                 @default(0)
  initialAssists   Int                 @default(0)
  lineupEntries    MatchLineup[]
  events           MatchEvent[]
  mentionedInPosts Post[]
  relatedProducts  Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

model PlayerTranslation {
  id       String  @id @default(cuid())
  playerId String
  player   Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  language String  @db.VarChar(5)
  name     String
  bio      String? @db.Text

  @@unique([playerId, language])
}

model Coach {
  id               String             @id @default(cuid())
  slug             String             @unique
  translations     CoachTranslation[]
  avatar           String?
  media            Media[]
  teamContext      TeamContext        @default(MAIN_TEAM)
  mentionedInPosts Post[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

model CoachTranslation {
  id       String  @id @default(cuid())
  coachId  String
  coach    Coach   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  language String  @db.VarChar(5)
  name     String
  role     String
  bio      String? @db.Text

  @@unique([coachId, language])
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
}

model Opponent {
  id           String                @id @default(cuid())
  slug         String                @unique
  logoUrl      String?
  translations OpponentTranslation[]
  matches      Match[]
}

model OpponentTranslation {
  id         String   @id @default(cuid())
  opponentId String
  opponent   Opponent @relation(fields: [opponentId], references: [id], onDelete: Cascade)
  language   String   @db.VarChar(5)
  name       String

  @@unique([opponentId, language])
}

model Tournament {
  id           String                  @id @default(cuid())
  slug         String                  @unique
  sofascoreId  Int?                    @unique
  translations TournamentTranslation[]
  matches      Match[]
  standings    Standing[]
  deletedAt    DateTime?

  @@index([deletedAt])
}

model TournamentTranslation {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  language     String     @db.VarChar(5)
  name         String

  @@unique([tournamentId, language])
}

model Standing {
  id           String      @id @default(cuid())
  rank         Int
  teamName     String
  teamLogo     String?
  points       Int
  played       Int
  win          Int
  draw         Int
  lose         Int
  goalsFor     Int         @default(0)
  goalsAgainst Int         @default(0)
  goalsDiff    Int
  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])
  seasonId     String?
  season       Season?     @relation(fields: [seasonId], references: [id])
  teamContext  TeamContext @default(MAIN_TEAM)

  updatedAt DateTime @updatedAt
}

model TeamDictionary {
  id           String                      @id @default(cuid())
  sofascoreId  Int                         @unique
  originalName String
  translations TeamDictionaryTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamDictionaryTranslation {
  id               String         @id @default(cuid())
  teamDictionaryId String
  teamDictionary   TeamDictionary @relation(fields: [teamDictionaryId], references: [id], onDelete: Cascade)
  language         String         @db.VarChar(5)
  name             String

  @@unique([teamDictionaryId, language])
}

model Match {
  id            String        @id @default(cuid())
  slug          String        @unique
  date          DateTime
  status        MatchStatus   @default(SCHEDULED)
  teamContext   TeamContext   @default(MAIN_TEAM)
  tournamentId  String?
  tournament    Tournament?   @relation(fields: [tournamentId], references: [id])
  seasonId      String?
  season        Season?       @relation(fields: [seasonId], references: [id])
  opponentId    String
  opponent      Opponent      @relation(fields: [opponentId], references: [id])
  isHomeGame    Boolean       @default(true)
  stadium       String?
  goalsScored   Int?
  goalsConceded Int?
  highlightsUrl String?
  fullMatchUrl  String?
  galleries     Gallery[]
  lineup        MatchLineup[]
  events        MatchEvent[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
  @@index([seasonId])
  @@index([teamContext])
}

model MatchLineup {
  id        String  @id @default(cuid())
  matchId   String
  match     Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  isStarter Boolean @default(false)
  played    Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([matchId, playerId])
}

enum EventType {
  GOAL
  ASSIST
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION_IN
  SUBSTITUTION_OUT
}

model MatchEvent {
  id       String    @id @default(cuid())
  matchId  String
  match    Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId String
  player   Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  type     EventType
  minute   Int

  createdAt DateTime @default(now())

  @@index([playerId])
  @@index([type])
}

model Category {
  id           String                @id @default(cuid())
  slug         String                @unique
  translations CategoryTranslation[]

  products  Product[]
  deletedAt DateTime?

  @@index([deletedAt])
}

model CategoryTranslation {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  language   String   @db.VarChar(5)
  name       String

  @@unique([categoryId, language])
}

model Product {
  id             String               @id @default(cuid())
  slug           String               @unique
  translations   ProductTranslation[]
  price          Decimal              @db.Decimal(10, 2)
  salePrice      Decimal?             @db.Decimal(10, 2)
  isOnSale       Boolean              @default(false)
  media          Media[]
  categoryId     String
  category       Category             @relation(fields: [categoryId], references: [id])
  sizes          String[]
  stock          Int                  @default(0)
  isArchived     Boolean              @default(false)
  isFeatured     Boolean              @default(false)
  orderItems     OrderItem[]
  relatedPlayers Player[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
  @@index([categoryId])
}

model ProductTranslation {
  id          String  @id @default(cuid())
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  language    String  @db.VarChar(5)
  name        String
  description String  @db.Text

  @@unique([productId, language])
}

enum OrderStatusEnum {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id         String          @id @default(cuid())
  userId     String?
  user       User?           @relation(fields: [userId], references: [id])
  status     OrderStatusEnum @default(PENDING)
  isPaid     Boolean         @default(false)
  totalPrice Decimal         @db.Decimal(10, 2)
  phone      String          @default("")
  address    String          @default("")
  orderItems OrderItem[]
  payment    Payment?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  quantity   Int
  size       String?
  fixedPrice Decimal @db.Decimal(10, 2)
}

model Payment {
  id            String  @id @default(cuid())
  orderId       String  @unique
  order         Order   @relation(fields: [orderId], references: [id])
  provider      String
  status        String
  transactionId String?
  details       Json?

  createdAt DateTime @default(now())
}

model Season {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String     @unique
  sofascoreId Int?       @unique
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean    @default(false)
  matches     Match[]
  standings   Standing[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}
